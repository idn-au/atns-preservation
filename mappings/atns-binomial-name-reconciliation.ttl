    a owl:Ontology ;
    dcterms:created "2026-07-14"^^xsd:date ;
    dcterms:description "Draft reconciliation of the heterogeneous legacy ATNS Binomial Names list. Organization links use schema:sameAs, geographic concepts use SKOS mappings, and unresolved values retain editorial notes."@en ;
